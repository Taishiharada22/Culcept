{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/git-safety.sh"
          }
        ]
      }
    ],
    "preToolCall": [
      {
        "matcher": "Bash(npx supabase db push*)",
        "hooks": [
          {
            "type": "confirm",
            "message": "⚠️ DB マイグレーション実行: CEO 承認が必要です。続行しますか？"
          }
        ]
      },
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "confirm",
            "message": "⚠️ リモートへの push: CEO 承認が必要です。続行しますか？"
          }
        ]
      },
      {
        "matcher": "Bash(npx next build*)",
        "hooks": [
          {
            "type": "confirm",
            "message": "⚠️ 本番ビルド実行: CEO 確認してください。続行しますか？"
          }
        ]
      }
    ]
  }
}
