# ═══════════════════════════════════════════════════════════════════════════
# Aneurasync — env var template
# ═══════════════════════════════════════════════════════════════════════════
#
# 本ファイルは **git 管理される公開 template**。
# 実値（特に secret）は `.env.local`（gitignore 済み）に書くこと。
#
# Vercel 環境では Project Settings → Environment Variables で登録する。
# Preview / Production で値を分ける場合は個別に設定すること。
#
# 現状カバー範囲:
#   - Alter Morning Visual Flow (PR-13)
# 既存 env var（Supabase / OpenAI / etc.）は後続 PR で追記予定。
#

# ───────────────────────────────────────────────────────────────────────────
# Alter Morning — Visual Flow (W3-PR-13)
# ───────────────────────────────────────────────────────────────────────────
# 設計書: docs/alter-morning-pr13-visual-flow-rollout-plan.md
# dead-code landing: 全 3 変数を空/false にしておけば本機能は絶対に fire しない。
#
# 優先順位（flags.ts §1-A-1）:
#   1. test override（`__setVisualFlowOverride(true|false)`）
#   2. allowlist（下記 _ALLOWLIST CSV に userId 含む）
#   3. global fallback（下記 bool env、既定 false）
#

# Global ON/OFF fallback。default OFF。
# Stage 5 で `true` にすると allowlist 外の全ユーザーへ展開される（最終段階）。
ALTER_MORNING_VISUAL_FLOW=false

# Canary allowlist（CSV of user UUID, lowercase 推奨）。default empty。
# Stage 4 で CEO + 指定テスターの UUID を列挙する。カンマ区切り。
# 例: ALTER_MORNING_VISUAL_FLOW_ALLOWLIST=aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee
ALTER_MORNING_VISUAL_FLOW_ALLOWLIST=

# Google Maps JavaScript API browser key（client-side / NEXT_PUBLIC_*）。
# default empty → MorningMapView は早期 null return し、JS API script も挿入されない。
#
# **発行手順 (Stage 3 で CEO が実行)**:
#   1. Google Cloud Console → APIs & Services → Credentials → Create Credentials → API key
#   2. Application restrictions: HTTP referrers
#        - Preview: `*.vercel.app/*`
#        - Production: `https://<your-prod-domain>/*`
#   3. API restrictions: 「Maps JavaScript API」のみ有効化
#   4. Quotas: Maps JavaScript API > Map loads per day を 1,000 等に上限設定
#   5. Vercel env 投入:
#        - Preview: 上記 Preview restricted key
#        - Production: 上記 Production restricted key（別キー推奨、障害切り分け用）
NEXT_PUBLIC_ALTER_MORNING_MAPS_BROWSER_KEY=
