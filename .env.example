# ═══════════════════════════════════════════════════════════════════════════
# Aneurasync — env var template
# ═══════════════════════════════════════════════════════════════════════════
#
# 本ファイルは **git 管理される公開 template**。
# 実値（特に secret）は `.env.local`（gitignore 済み）に書くこと。
#
# Vercel 環境では Project Settings → Environment Variables で登録する。
# Preview / Production で値を分ける場合は個別に設定すること。
#
# 現状カバー範囲:
#   - Alter Morning Visual Flow (PR-13)
# 既存 env var（Supabase / OpenAI / etc.）は後続 PR で追記予定。
#

# ───────────────────────────────────────────────────────────────────────────
# Alter Morning — Visual Flow (W3-PR-13)
# ───────────────────────────────────────────────────────────────────────────
# 設計書: docs/alter-morning-pr13-visual-flow-rollout-plan.md
# dead-code landing: 全 3 変数を空/false にしておけば本機能は絶対に fire しない。
#
# 優先順位（flags.ts §1-A-1）:
#   1. test override（`__setVisualFlowOverride(true|false)`）
#   2. allowlist（下記 _ALLOWLIST CSV に userId 含む）
#   3. global fallback（下記 bool env、既定 false）
#

# Global ON/OFF fallback。default OFF。
# Stage 5 で `true` にすると allowlist 外の全ユーザーへ展開される（最終段階）。
ALTER_MORNING_VISUAL_FLOW=false

# Canary allowlist（CSV of user UUID, lowercase 推奨）。default empty。
# Stage 4 で CEO + 指定テスターの UUID を列挙する。カンマ区切り。
# 例: ALTER_MORNING_VISUAL_FLOW_ALLOWLIST=aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee
ALTER_MORNING_VISUAL_FLOW_ALLOWLIST=

# Google Maps JavaScript API browser key（client-side / NEXT_PUBLIC_*）。
# default empty → MorningMapView は早期 null return し、JS API script も挿入されない。
#
# **発行手順 (Stage 3 で CEO が実行)**:
#   1. Google Cloud Console → APIs & Services → Credentials → Create Credentials → API key
#   2. Application restrictions: HTTP referrers
#        - Preview: `*.vercel.app/*`
#        - Production: `https://<your-prod-domain>/*`
#   3. API restrictions: 「Maps JavaScript API」のみ有効化
#   4. Quotas: Maps JavaScript API > Map loads per day を 1,000 等に上限設定
#   5. Vercel env 投入:
#        - Preview: 上記 Preview restricted key
#        - Production: 上記 Production restricted key（別キー推奨、障害切り分け用）
NEXT_PUBLIC_ALTER_MORNING_MAPS_BROWSER_KEY=

# ───────────────────────────────────────────────────────────────────────────
# Google Calendar OAuth (= P3-A-1-1、 2026-05-26 着手)
# ───────────────────────────────────────────────────────────────────────────
# 設計書:
#   - docs/alter-plan-p3-a-1-google-calendar-readiness.md (= 親 readiness、 12 問確定)
#   - docs/alter-plan-p3-a-1-1-oauth-scaffold-readiness.md (= OAuth scaffold 8 項目)
#
# 役割:
#   - Aneurasync が user の Google Calendar を OAuth 経由で読み取る (= 認証用ではなく連携用)
#   - 既存 Supabase Auth (= email/password) とは完全独立した OAuth client
#   - scope: calendar.events.readonly + calendar.calendarlist.readonly (= 親 Q2 採用案 c)
#
# **発行手順 (CEO が 2026-05-26 実行済)**:
#   1. Google Cloud Console → 既存 Aneurasync project → APIs & Services → Credentials
#   2. Create Credentials → OAuth client ID → Web application
#   3. Authorized redirect URIs:
#        - Production: https://aneurasync.com/api/calendar/google/callback
#        - Development: http://localhost:3000/api/calendar/google/callback
#   4. Client ID / Client Secret を取得 → .env.local に登録 (= secret は commit / docs / chat 載せず)
#   5. OAuth consent screen の Support email: aneurasync@outlook.com
#
# **server-side のみ**: NEXT_PUBLIC_ prefix なし (= browser に漏らさない)
# default empty → connect route は 「未設定」 として user に明示 (= /api/calendar/google/connect が
#                 400 を返す or 設定不備 banner 表示、 実装は P3-A-1-1-c)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Redirect URI (= 必ず Google Cloud Console 登録値と一致させる)
# default は production 値。 local 開発時は .env.local で
#   GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback
# に上書き。
GOOGLE_CALENDAR_REDIRECT_URI=https://aneurasync.com/api/calendar/google/callback

# OAuth state cookie HMAC secret (= CSRF 防止用、 connect/callback 間の state 改竄検出)
# 32 bytes random base64 推奨。 発行手順:
#   openssl rand -base64 32
# server-side only (= NEXT_PUBLIC_ prefix なし)。 default empty → connect route は degrade
OAUTH_STATE_SECRET=

# OAuth refresh_token 暗号化キー (= AES-256-GCM、 user_calendar_connections.refresh_token_encrypted 用)
# 32 bytes random base64 (= 厳密)。 発行手順:
#   openssl rand -base64 32  ← 必ず 32 bytes (= 44 文字 base64 with padding)
# server-side only。 default empty → callback route は degrade (= P3-A-1-1-d)
# 重要: rotation 時は既存暗号化 token も再暗号化が必要 (= rotation 手順は別 phase)
OAUTH_TOKEN_ENCRYPTION_KEY=
